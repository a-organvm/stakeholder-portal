# Cron trigger auth
CRON_SECRET=
CRON_CONNECTOR_IDS=docs,workspace

# Outbound alert sinks + retry
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
ALERT_SLACK_MENTION_CRITICAL=
ALERT_SLACK_MENTION_WARNING=
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SINKS_DISABLED=0
ALERT_DISPATCH_WARNINGS=0
ALERT_DISPATCH_INFO=0
ALERT_SINK_MAX_RETRIES=2
ALERT_SINK_RETRY_BASE_MS=250
# JSON string, example:
# ALERT_ROUTING_JSON={"critical_channels":["webhook","slack","email"],"warning_channels":["webhook"]}
